# ------------------------------
# Required recipe parameters
# ------------------------------

# Model auth mode used by clawchef bootstrap
CLAWCHEF_VAR_AUTH_CHOICE=openai-api-key

# Provide the key for your selected auth choice
CLAWCHEF_VAR_OPENAI_API_KEY=
# CLAWCHEF_VAR_ANTHROPIC_API_KEY=
# CLAWCHEF_VAR_OPENROUTER_API_KEY=

# Telegram bot token from BotFather
CLAWCHEF_VAR_TELEGRAM_BOT_TOKEN_LOOMPLUS=

# LoomPlus MCP access token
CLAWCHEF_VAR_LOOMPLUS_MCP_ACCESS_TOKEN=


# ------------------------------
# Optional recipe parameters
# ------------------------------

# CLAWCHEF_VAR_OPENCLAW_VERSION=2026.2.9
# CLAWCHEF_VAR_PROJECT_NAME=workspace-meeting
# CLAWCHEF_VAR_AGENT_NAME=loomplus-meeting
# CLAWCHEF_VAR_AGENT_MODEL=anthropic/claude-opus-4-6


# ------------------------------
# Recipe smoke test options
# ------------------------------

# Path to telegram-api-mock-server test CA cert
TELEGRAM_MOCK_CA_CERT=/etc/telegram-mock/test-ca.crt
